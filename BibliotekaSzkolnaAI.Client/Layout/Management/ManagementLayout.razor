@inherits LayoutComponentBase
@layout MainLayout

<div class="d-flex flex-column vh-100 w-100">

    <header class="sticky-top">
        <ManagementNavbar />
    </header>

    <main class="w-100 flex-grow-1">

        <div class="container-fluid g-0 h-100">

            <div class="row g-0 h-100">

                <aside class="col-md-2 h-100">
                    <NavMenu />
                </aside>

                <div class="col-md-10 p-3 h-100">
                     @Body
                </div>
            </div>
        </div> 

    </main>

    <footer>
        <ManagementFooter />
    </footer>

</div>