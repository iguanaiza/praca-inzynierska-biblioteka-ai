@page "/panel/dashboard"
@using Syncfusion.Blazor.Charts
@using BibliotekaSzkolnaAI.Shared.DataTransferObjects.Books.Catalog
@layout ManagementLayout
@attribute [Authorize(Roles = "Admin,Librarian")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Dashboard - Biblioteka</PageTitle>

@if (IsLoading)
{
    <div class="d-flex flex-column justify-content-center align-items-center" style="height: 60vh">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <p class="mt-3 text-muted"><em>Ładowanie statystyk biblioteki...</em></p>
    </div>
}
else
{
    <div class="container-fluid px-4 fade-in">
        <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
            <div>
                <h1 class="h3 mb-0 theme-font-col-pri visually-hidden">Pulpit</h1>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-warning py-1 px-3 mb-0 shadow-sm border-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Tryb offline (Błąd API: @errorMessage)
                </div>
            }
        </div>

        <div class="row g-4 mb-4">

            <div class="col-lg-8">

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <div class="card card-db primary theme-font-col-pri h-100 shadow-sm border-0">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="text-uppercase small fw-bold opacity-75">Oczekujące</div>
                                        <div class="display-6 fw-bold mt-2">@(stats.PendingLoanApprovalsCount + stats.PendingReturnApprovalsCount)</div>
                                    </div>
                                    <i class="bi bi-hourglass-split fs-1 opacity-50"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card card-db primary theme-font-col-pri h-100 shadow-sm border-0">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="text-uppercase small fw-bold opacity-75">Przetrzymane</div>
                                        <div class="display-6 fw-bold mt-2">@stats.OverdueLoansCount</div>
                                    </div>
                                    <i class="bi bi-exclamation-circle fs-1 opacity-50"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card card-db primary theme-font-col-pri h-100 shadow-sm border-0">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="text-uppercase small fw-bold opacity-75">Wypożyczone</div>
                                        <div class="display-6 fw-bold mt-2">@(stats.ActiveLoansCount + stats.OverdueLoansCount)</div>
                                    </div>
                                    <i class="bi bi-book fs-1 opacity-50"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-db shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h6 class="m-0 fw-bold theme-font-col-pri"><i class="bi bi-bar-chart-fill me-1"></i> Wypożyczenia (6 m-cy)</h6>
                    </div>
                    <div class="card-body">
                        @if (stats.LoansPerMonth != null && stats.LoansPerMonth.Count > 0)
                        {
                            <SfChart>
                                <ChartArea><ChartAreaBorder Width="0"></ChartAreaBorder></ChartArea>
                                <ChartPrimaryXAxis ValueType="Syncfusion.Blazor.Charts.ValueType.Category">
                                    <ChartAxisMajorGridLines Width="0"></ChartAxisMajorGridLines>
                                </ChartPrimaryXAxis>
                                <ChartPrimaryYAxis>
                                    <ChartAxisLineStyle Width="0"></ChartAxisLineStyle>
                                </ChartPrimaryYAxis>
                                <ChartTooltipSettings Enable="true"></ChartTooltipSettings>
                                <ChartSeriesCollection>
                                    <ChartSeries DataSource="@stats.LoansPerMonth" XName="MonthName" YName="Count" Type="ChartSeriesType.Column" Fill="var(--primary)">
                                        <ChartMarker>
                                            <ChartDataLabel Visible="true" Position="Syncfusion.Blazor.Charts.LabelPosition.Top">
                                                <ChartDataLabelFont FontWeight="600" Color="var(--font-secondary)"></ChartDataLabelFont>
                                            </ChartDataLabel>
                                        </ChartMarker>
                                        <ChartCornerRadius TopLeft="5" TopRight="5"></ChartCornerRadius>
                                    </ChartSeries>
                                </ChartSeriesCollection>
                            </SfChart>
                        }
                        else
                        {
                            <div class="d-flex justify-content-center align-items-center text-muted" style="min-height: 250px;">
                                <p>Brak danych historycznych</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card card-db h-100 shadow-sm border-0">
                    <div class="card-header py-3">
                        <h6 class="m-0 theme-font-col-pri"><i class="bi bi-star-fill me-1"></i> Polecane</h6>
                    </div>

                    @if (!stats.RecommendedBooks.Any())
                    {
                        <div class="card-body d-flex align-items-center justify-content-center theme-font-col-pri">
                            <p>Brak polecanych książek.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var book in stats.RecommendedBooks)
                            {
                                <li class="list-group-item py-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-bookmark-star theme-font-color me-3 fs-5"></i>
                                        <div class="flex-grow-1 overflow-hidden">
                                            <a href="/panel/zasoby/ksiazki/szczegoly/@book.Id?returnUrl=/panel/dashboard" class="text-decoration-none fw-bold text-truncate d-block theme-font-col-pri" title="@book.Title">
                                                @book.Title
                                            </a>
                                        </div>
                                        <small class="theme-font-color ms-2">
                                            <i class="bi bi-chevron-right"></i>
                                        </small>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

        </div>
    </div>
}

@code {
    private bool IsLoading = true;
    private string? errorMessage;

    private DashboardViewModel stats = new()
    {
        LoansPerMonth = new(),
        RecommendedBooks = new()
    };

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        try
        {
            var result = await Http.GetFromJsonAsync<DashboardViewModel>("api/management/dashboard");

            if (result != null)
            {
                stats = result;
                if (stats.LoansPerMonth == null) stats.LoansPerMonth = new();
                if (stats.RecommendedBooks == null) stats.RecommendedBooks = new();
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}