@page "/panel/zasoby/ksiazki/dodaj"
@page "/panel/zasoby/ksiazki/szczegoly/{BookId:int}/edytuj"
@page "/panel/zasoby/ksiazki/edytuj/{BookId:int}"

@layout ManagementLayout
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject IConfiguration Configuration
@inject GlobalUiService UI

<PageTitle>@(BookId == 0 ? "Dodaj" : "Edytuj") książkę</PageTitle>

@if (IsLoading)
{
    <div class="text-center" role="status">
        <img src="/images/loading-book.gif" alt="Ikona ładowania formularza." />
        <p><em>Ładowanie formularza...</em></p>
    </div>
}

else if (LoadError)
{
    <div class="alert alert-danger m-4 text-center">
        <h2>Błąd</h2>
        <p>Nie udało się załadować danych.</p>
        <button class="btn btn-primary btn-lg" @onclick="GoBack">Powrót</button>
    </div>
}
else
{
    <div class="card shadow border-0 m-4">
        <div class="card-header bg-theme bg-gradient ml-0 py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="py-2 text-white">@(BookId == 0 ? "Dodaj" : "Edytuj") książkę</h2>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row pb-3">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 m-auto">
                    <button name="Powrót"
                            class="btn btn-primary btn-lg"
                            @onclick="GoBack">

                        <i class="bi bi-arrow-bar-left"
                           aria-hidden="true"></i> Powrót
                    </button>
                </div>
            </div>

            <div class="card shadow p-4 mx-auto">
                <EditForm Model="book" OnValidSubmit="UpsertBookFormSubmit">
                    <DataAnnotationsValidator />

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookTitle">Tytuł</label>
                                <SfTextBox ID="bookTitle" @bind-Value="book.Title" Placeholder="Wpisz tytuł książki"></SfTextBox>
                                <ValidationMessage For="@(() => book.Title)" />
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookAuthor">Autor</label>
                                <SfComboBox ID="bookAuthor" TValue="int" TItem="LookupDto" DataSource="@lookups.Authors"
                                            @bind-Value="book.BookAuthorId" Placeholder="Wybierz autora" AllowFiltering="true">
                                    <ComboBoxFieldSettings Value="Id" Text="Name"></ComboBoxFieldSettings>
                                </SfComboBox>
                                <ValidationMessage For="@(() => book.BookAuthorId)" />
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookDescription">Opis</label>
                                <SfTextArea ID="bookDescription" @bind-Value="book.Description" RowCount="4" ColumnCount="100" Placeholder="Krótki opis fabuły..." Width="100%"></SfTextArea>
                                <ValidationMessage For="@(() => book.Description)" />
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookPublisher">Wydawca</label>
                                <SfComboBox ID="bookPublisher" TValue="int" TItem="LookupDto" DataSource="@lookups.Publishers"
                                            @bind-Value="book.BookPublisherId" Placeholder="Wybierz wydawcę" AllowFiltering="true">
                                    <ComboBoxFieldSettings Value="Id" Text="Name"></ComboBoxFieldSettings>
                                </SfComboBox>
                                <ValidationMessage For="@(() => book.BookPublisherId)" />
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookIsbn">ISBN</label>
                                <SfTextBox ID="bookIsbn" @bind-Value="book.Isbn" Placeholder="ISBN"></SfTextBox>
                                <ValidationMessage For="@(() => book.Isbn)" />
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold" for="bookYear">Rok wydania</label>
                                    <SfNumericTextBox ShowSpinButton="false" ID="bookYear" TValue="int" @bind-Value="book.Year" Format="####" Decimals="0" ValidateDecimalOnType="true"></SfNumericTextBox>
                                    <ValidationMessage For="@(() => book.Year)" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold" for="bookPageCount">Liczba stron</label>
                                    <SfNumericTextBox ShowSpinButton="false" ID="bookPageCount" TValue="int" @bind-Value="book.PageCount" Decimals="0"></SfNumericTextBox>
                                    <ValidationMessage For="@(() => book.PageCount)" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookSeries">Seria</label>
                                <SfComboBox ID="bookSeries" TValue="int" TItem="LookupDto" DataSource="@lookups.Series"
                                            @bind-Value="book.BookSeriesId" Placeholder="-- Brak serii --" AllowFiltering="true">
                                    <ComboBoxFieldSettings Value="Id" Text="Name"></ComboBoxFieldSettings>
                                </SfComboBox>
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookType">Typ</label>
                                <SfComboBox ID="bookType" TValue="int" TItem="LookupDto" DataSource="@lookups.Types"
                                            @bind-Value="book.BookTypeId" Placeholder="Wybierz typ">
                                    <ComboBoxFieldSettings Value="Id" Text="Name"></ComboBoxFieldSettings>
                                </SfComboBox>
                            </div>

                            <div class="mb-3 w-100">
                                <label class="form-label fw-bold" for="bookGenre">Gatunki</label>
                                <SfMultiSelect ID="bookGenre" TValue="List<int>" TItem="LookupDto" DataSource="@lookups.Genres"
                                               @bind-Value="book.BookGenreIds" Placeholder="Wybierz gatunki" Mode="VisualMode.Box">
                                    <MultiSelectFieldSettings Value="Id" Text="Name"></MultiSelectFieldSettings>
                                </SfMultiSelect>
                                @if (book.BookGenreIds == null || !book.BookGenreIds.Any())
                                {
                                    <div class="text-danger small mt-1">Wybierz co najmniej jeden gatunek.</div>
                                }
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold" for="bookCategory">Kategoria</label>
                                    <SfComboBox ID="bookCategory" TValue="int" TItem="LookupDto" DataSource="@lookups.Categories"
                                                @bind-Value="book.BookCategoryId" Placeholder="Wybierz kategorię" AllowFiltering="true">
                                        <ComboBoxFieldSettings Value="Id" Text="Name"></ComboBoxFieldSettings>
                                    </SfComboBox>
                                    <ValidationMessage For="@(() => book.BookCategoryId)" />
                                 </div>

                                @if (SelectedCategoryName?.ToLower().Contains("podręcznik") == true)
                                {
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label small" for="bookSubject">Przedmiot</label>
                                        <SfComboBox ID="bookSubject" TValue="string" TItem="string" DataSource="@Subjects"
                                                    @bind-Value="book.Subject" Placeholder="Wybierz przedmiot" AllowFiltering="true">
                                        </SfComboBox>
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label small" for="bookClass">Klasa</label>
                                        <SfComboBox ID="bookClass" TValue="string" TItem="string" DataSource="@Classes2"
                                                    @bind-Value="book.Class" Placeholder="Wybierz klasę">
                                        </SfComboBox>
                                    </div>
                                }

                                else if (SelectedCategoryName?.ToLower().Contains("lektura") == true)
                                {
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label small" for="bookClasses">Klasy</label>
                                        <SfComboBox ID="bookClasses" TValue="string" TItem="string" DataSource="@Classes"
                                                    @bind-Value="book.Class" Placeholder="Wybierz klasy">
                                        </SfComboBox>
                                    </div>
                                }
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold" for="bookTags">Specjalne</label>
                                <div id="bookTags" class="d-flex flex-wrap gap-3 p-2 border rounded">
                                    @foreach (var tag in lookups.SpecialTags)
                                    {
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="tag-@tag.Id"
                                                   checked="@(book.BookSpecialTagIds?.Contains(tag.Id) ?? false)"
                                                   @onchange="@(() => ToggleSpecialTag(tag.Id))" />
                                            <label class="form-check-label cursor-pointer" for="tag-@tag.Id">@tag.Name</label>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Widoczność w katalogu</label>
                                <div class="d-flex flex-wrap gap-3 p-2 border rounded">
                                    <SfRadioButton Label="Widoczna"
                                                   Name="VisibilityGroup"
                                                   Value="true"
                                                   TChecked="bool"
                                                   Checked="@(book.IsVisible)"
                                                   ValueChange="@((Syncfusion.Blazor.Buttons.ChangeArgs<bool> args) => { book.IsVisible = true; })">
                                    </SfRadioButton>

                                    <SfRadioButton Label="Ukryta"
                                                   Name="VisibilityGroup"
                                                   Value="false"
                                                   TChecked="bool"
                                                   Checked="@(!book.IsVisible)"
                                                   ValueChange="@((Syncfusion.Blazor.Buttons.ChangeArgs<bool> args) => { book.IsVisible = false; })">
                                    </SfRadioButton>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 d-flex flex-column border-start ps-4">

                            <div class="d-flex flex-column flex-grow-1 mb-3">
                                <label class="form-label fw-bold mb-2">Okładka książki</label>

                                <div class="card flex-grow-1 shadow-sm">
                                    <div class="card-body bg-light d-flex flex-column justify-content-center align-items-center" style="max-height:500px;">

                                        @if (!string.IsNullOrEmpty(book.ImageUrl))
                                        {
                                            <div class="flex-grow-1 d-flex align-items-center justify-content-center h-100 overflow-hidden">
                                                <img src="@GetImageUrl(book.ImageUrl)"
                                                     alt="Okładka"
                                                     class="img-fluid rounded shadow-sm details-image" />
                                            </div>

                                            <div class="w-100 mt-3">
                                                <button type="button" class="btn btn-outline-danger btn-sm h-100" @onclick="DeleteImage">
                                                    <i class="bi bi-trash"></i> Usuń zdjęcie
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted mb-4 text-center">
                                                <i class="bi bi-image display-1"></i>
                                                <p class="small mt-2">Brak okładki</p>
                                            </div>

                                            <div class="w-100">
                                                <SfUploader AutoUpload="false" AllowMultiple="false" AllowedExtensions=".jpg, .png, .jpeg, .webp">
                                                    <UploaderEvents ValueChange="OnImageUpload"></UploaderEvents>
                                                </SfUploader>
                                                <div class="form-text text-muted text-center small mt-2">Formaty: .jpg, .png. Max 5MB.</div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                        </div>

                        <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                            <button type="button" class="btn btn-secondary" @onclick="GoBack">
                                Anuluj
                            </button>

                            <button type="submit" class="btn btn-primary btn-lg" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-save"></i> @(BookId == 0 ? "Utwórz książkę" : "Zapisz zmiany")
                            </button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int BookId { get; set; }
    [Parameter][SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private BookUpsertDto book = new BookCreateDto();
    private BookLookupsDto lookups = new();

    private bool IsLoading = true;
    private bool LoadError = false;
    private bool isSubmitting = false;
    private string? errorMessage;

    private List<string> Subjects = new() { "Język polski", "Matematyka", "Historia", "Przyroda", "Biologia", "Chemia", "Fizyka", "Geografia", "Informatyka", "Technika", "Muzyka", "Plastyka", "Język angielski", "Język niemiecki" };
    private List<string> Classes = new() { "I-III", "IV-VI", "VII-VIII" };
    private List<string> Classes2 = new() { "I", "II", "III", "IV", "V", "VI", "VII", "VIII" };

    private string? SelectedCategoryName => lookups.Categories.FirstOrDefault(c => c.Id == book.BookCategoryId)?.Name;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            lookups = await Http.GetFromJsonAsync<BookLookupsDto>("api/management/books/lookups") ?? new();

            if (BookId > 0)
            {
                book = new BookEditDto { BookGenreIds = new(), BookSpecialTagIds = new() };

                var details = await Http.GetFromJsonAsync<BookGetDetailedDto>($"api/management/books/details/{BookId}");

                if (details != null)
                {
                    MapDetailsToEdit(details);
                }
                else
                {
                    LoadError = true;
                }
            }
            else
            {
                book = new BookCreateDto { BookGenreIds = new(), BookSpecialTagIds = new() };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            LoadError = true;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void MapDetailsToEdit(BookGetDetailedDto d)
    {
        book.Title = d.Title;
        book.Year = d.Year;
        book.Description = d.Description;
        book.Isbn = d.Isbn;
        book.PageCount = d.PageCount;
        book.ImageUrl = d.ImageUrl;
        book.Subject = d.Subject;
        book.Class = d.Class;
        book.BookAuthorId = d.BookAuthorId;
        book.BookPublisherId = d.BookPublisherId;
        book.BookSeriesId = d.BookSeriesId;
        book.BookTypeId = d.BookTypeId;
        book.BookCategoryId = d.BookCategoryId;
        book.BookGenreIds = d.BookGenreIds ?? new();
        book.BookSpecialTagIds = d.BookSpecialTagIds ?? new();

        if (book is BookEditDto edit)
        {
            edit.IsVisible = d.IsVisible;
        }
    }

    private void ToggleSpecialTag(int id)
    {
        if (book.BookSpecialTagIds == null) book.BookSpecialTagIds = new();

        if (book.BookSpecialTagIds.Contains(id)) book.BookSpecialTagIds.Remove(id);
        else book.BookSpecialTagIds.Add(id);
    }

    private async Task UpsertBookFormSubmit()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            HttpResponseMessage response;

            if (BookId > 0)
            {
                response = await Http.PutAsJsonAsync($"api/management/books/edit/{BookId}", (BookEditDto)book);
            }
            else
            {
                response = await Http.PostAsJsonAsync("api/management/books/create", (BookCreateDto)book);
            }

            if (response.IsSuccessStatusCode)
            {
                UI.ShowToast(BookId == 0 ? "Dodano książkę! Za chwilę nastąpi powrót do poprzedniej strony." : "Zapisano zmiany! Za chwilę nastąpi powrót do poprzedniej strony.", "success");
                await Task.Delay(3000);
                GoBack();
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                UI.ShowToast($"Nie udało się zapisać: {errorMsg}", "error");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Błąd sieci: {ex.Message}";
            UI.ShowToast("Wystąpił błąd połączenia z serwerem.", "error");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        if (!string.IsNullOrEmpty(ReturnUrl)) NavigationManager.NavigateTo(ReturnUrl);
        else NavigationManager.NavigateTo("/panel/zasoby/ksiazki");
    }

    private async Task OnImageUpload(UploadChangeEventArgs args)
    {
        try
        {
            var apiBaseUrl = Configuration["ApiBaseUrl"];

            if (string.IsNullOrEmpty(apiBaseUrl))
            {
                await JS.InvokeVoidAsync("alert", "Błąd konfiguracji: Brak ApiBaseUrl.");
                return;
            }

            var uploadUrl = $"{apiBaseUrl.TrimEnd('/')}/api/fileupload/upload";

            foreach (var file in args.Files)
            {
                using var content = new MultipartFormDataContent();

                var fileContent = new StreamContent(file.Stream);
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.FileInfo.Type ?? "image/jpeg");

                content.Add(fileContent, "file", file.FileInfo.Name);

                var response = await Http.PostAsync(uploadUrl, content);

                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                    if (result != null)
                    {
                        book.ImageUrl = result.Url;
                        StateHasChanged();
                    }
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"Upload error: {error}");
                    await JS.InvokeVoidAsync("alert", "Błąd przesyłania pliku.");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Wyjątek: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Wystąpił błąd podczas wysyłania.");
        }
    }

    private void DeleteImage()
    {
        book.ImageUrl = null;
    }

    private string GetImageUrl(string? relativePath)
    {
        if (string.IsNullOrEmpty(relativePath))
        {
            return "images/no-cover.png";
        }

        var apiBaseUrl = Configuration["ApiBaseUrl"];

        if (string.IsNullOrEmpty(apiBaseUrl))
        {
            return relativePath;
        }
        return $"{apiBaseUrl.TrimEnd('/')}/{relativePath.TrimStart('/')}";
    }
}